---
import { SiteConfig } from '../config.ts';
import Layout from '../layouts/Layout.astro';
import { Icon } from "astro-icon/components";
import Comment from '../components/Comment.astro';
import LinkPage  from '../content/link.md';
import { links } from '../data/links.ts';


const Page = '友链';
---

<Layout pagetitle={`${Page} - ${SiteConfig.title}`}>
  <div class="links-container">
    <h1 class="text-2xl font-bold text-center" style="color: var(--title-color);">{Page}</h1>
    <p class="text-center mb-[30px]">与各位博主无限进步</p>
    
    <div class="links-grid">
      {links.map((link, index) => (
        <div class="link-card animate-slide-in" style={{ animationDelay: `${index * 0.05}s` }} data-key={link.name}>
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-card-inner">
            <div class="link-avatar-container">
              <img src={link.avatar} alt={link.name} class="link-avatar" />
            </div>
            <div class="link-info">
              <div class="link-header">
                <h3 class="link-name">{link.name}</h3>
                <Icon name="tabler:arrow-up-right" class="link-icon" />
              </div>
              <p class="link-description">{link.description}</p>
            </div>
          </a>
        </div>
      ))}
    </div>
    <!-- 评论区 -->
    <Comment />
  </div>
</Layout>

<style>
  .links-container {
    max-width: var(--width);
    margin: 0 auto;
  }
  
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--gap);
    margin-bottom: 40px;
  }
  
  .link-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
    
  }
  
  .link-card:hover {
    border-color: var(--theme-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-color);
  }
  
  .link-card-inner {
    display: flex;
    align-items: center;
    padding: 12px;
    text-decoration: none;
    color: var(--text-color);
    gap: 12px;
  }
  
  .link-avatar-container {
    flex-shrink: 0;
  }
  
  .link-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .link-info {
    flex: 1;
    min-width: 0;
  }
  
  .link-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }
  
  .link-name {
    font-size: var(--font-text-size);
    font-weight: 500;
    color: var(--title-color);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .link-icon {
    width: 20px;
    height: 20px;
    color: var(--text-color);
    opacity: 0.6;
  }
  
  .link-description {
    font-size: var(--font-desc-size);
    color: var(--text-color);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    
  }
    
  /* 响应式设计 */
  @media (max-width: 768px) {
    .links-grid {
      grid-template-columns: 1fr;
      gap: var(--gap);
    }
    
    .link-card-inner {
      padding: 12px;
      gap: 12px;
    }
    
    .link-avatar {
      width: 48px;
      height: 48px;
    }
    
    .link-name {
      font-size: var(--font-text-size);
    }
    
    .link-description {
      font-size: var(--font-desc-size);
    }
  }

</style>