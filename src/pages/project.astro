---
import { SiteConfig } from '../config.ts';
import Layout from '../layouts/Layout.astro';
import { Icon } from "astro-icon/components";

// 语言图标映射
const languageIcons = {
  'TypeScript': 'tabler:brand-typescript',
  'JavaScript': 'tabler:brand-javascript',
  'HTML': 'tabler:brand-html5',
  'CSS': 'tabler:brand-css3',
  'Astro': 'tabler:brand-astro',
  'Python': 'tabler:brand-python',
  'Java': 'tabler:brand-java',
  'C++': 'tabler:brand-cpp',
  'C#': 'tabler:brand-csharp',
  'JS': 'tabler:brand-javascript',
};

// 项目数据
const projects = [
  {
    name: "MangoCat",    
    description: "基于 Astro 框架开发的个人博客主题项目，以简洁、现代的设计风格重构博客体验。(项目开发中)",
    demoUrl: "https://blog.almango.cn/",
    githubUrl: "https://github.com/Almango/MangoCat",
    tags: ["Astro", "博客", "主题"],
    language: "Astro"  },

  {
    name: "SimulateMoki-sjzxd",
    description: "基于Html + JS实现的一款三角洲行动烽火地带的网页版摸金模拟器，专注于还原游戏中的核心摸金体验。",
    demoUrl: "https://moki.almango.cn/",
    githubUrl: "https://github.com/Almango/SimulateMoki-sjzxd",
    tags: ["HTML", "JS", "游戏"], 
    language: "JavaScript"  },


  {
    name: "NavGo",
    description: "基于Astro开发的简约实用的自用型导航器，专注于为个人提供便捷的导航服务。",
    demoUrl: "https://navgo.almango.cn/",
    githubUrl: "https://github.com/Almango/NavGo",
    tags: ["Astro", "JSON", "导航"], 
    language: "Astro"  },
];

---

<Layout pagetitle={`项目 - ${SiteConfig.title}`}>
  <div class="projects-container">
    <h1 class="text-3xl font-bold" style="color: var(--title-color);">项目</h1>
    <p class="projects-subtitle">我的开源项目</p>

    <div class="projects-grid">
      {projects.map((project, index) => (
        <div class="project-card animate-slide-in" style={{ animationDelay: `${index * 0.1}s` }} data-key={project.name}>
          {project.githubUrl ? (
            <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="project-header project-header-link" title="查看 GitHub 仓库">
              <b class="project-name">{project.name}</b>
              <span class="project-link-indicator">
                <Icon name="tabler:arrow-up-right" class="project-link-arrow" />
              </span>
              {project.language && (
                <div class="project-language">
                  <Icon name={languageIcons[project.language] || 'tabler:brand'} class="project-language-icon" />
                </div>
              )}
            </a>
          ) : (
            <div class="project-header">
              <h2 class="project-name">{project.name}</h2>
              {project.language && (
                <div class="project-language">
                  <Icon name={languageIcons[project.language] || 'tabler:brand'} class="project-language-icon" />
                </div>
              )}
            </div>
          )}
          
          <p class="project-description">{project.description}</p>
   
          
          {project.githubUrl && (
            <div class="project-stats" data-github-url={project.githubUrl}>
              <div class="stat-item">
                <Icon name="tabler:star" />
                <span class="stat-count" data-stat="stars">-</span>
              </div>
              <div class="stat-item">
                <Icon name="tabler:git-fork" />
                <span class="stat-count" data-stat="forks">-</span>
              </div>
              {project.demoUrl && (
                <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="stat-item preview-link" title="在线预览">
                  <Icon name="tabler:device-imac" />
                  <span class="stat-demo" data-stat="views">Demo site</span>
                </a>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  // 获取 GitHub 统计数据
  async function fetchGitHubStats() {
    const statElements = document.querySelectorAll('.project-stats[data-github-url]');
    console.log('Found stat elements:', statElements.length);
    
    for (const element of statElements) {
      const githubUrl = element.getAttribute('data-github-url');
      console.log('Processing URL:', githubUrl);
      
      if (!githubUrl) {
        console.log('No githubUrl, skipping');
        continue;
      }
      
      try {
        // 解析 GitHub URL
        const match = githubUrl.match(/github\.com\/([^\/]+)\/([^\/]+)/);
        console.log('URL match:', match);
        
        if (!match) {
          console.log('No match found');
          continue;
        }
        
        const [, owner, repo] = match;
        console.log('Owner:', owner, 'Repo:', repo);
        
        // 调用 GitHub API
        const apiUrl = `https://api.github.com/repos/${owner}/${repo}`;
        console.log('Fetching:', apiUrl);
        
        const response = await fetch(apiUrl, {
          headers: {
            'Accept': 'application/vnd.github.v3+json',
            'User-Agent': 'MangoCat-Portfolio'
          }
        });
        console.log('Response status:', response.status);
        
        if (!response.ok) {
          console.log('Response not OK');
          continue;
        }
        
        const data = await response.json();
        console.log('Data received:', data.stargazers_count, data.forks_count);
        
        // 更新显示
        const starsElement = element.querySelector('[data-stat="stars"]');
        const forksElement = element.querySelector('[data-stat="forks"]');
        
        console.log('Stars element:', starsElement, 'Forks element:', forksElement);
        
        if (starsElement) {
          starsElement.textContent = formatNumber(data.stargazers_count || 0);
          console.log('Updated stars to:', starsElement.textContent);
        }
        if (forksElement) {
          forksElement.textContent = formatNumber(data.forks_count || 0);
          console.log('Updated forks to:', forksElement.textContent);
        }
      } catch (error) {
        console.error('Failed to fetch GitHub stats:', error);
      }
    }
  }
  
  // 格式化数字
  function formatNumber(num) {
    if (num >= 1000000) {
      return (num / 1000000).toFixed(1) + 'M';
    }
    if (num >= 1000) {
      return (num / 1000).toFixed(1) + 'k';
    }
    return num.toString();
  }
  
  // 页面加载完成后获取数据
  document.addEventListener('DOMContentLoaded', fetchGitHubStats);
  console.log('Script loaded, waiting for DOMContentLoaded');
</script>

<style>
  .projects-container {
    max-width: var(--width);
    margin: 0 auto;
  }
  
  .projects-subtitle {
    font-size: calc(var(--font-title-size) - 5px);
    color: var(--text-color);
    margin-bottom: 25px;
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--gap);
    margin-bottom: 40px;
  }
  
  .project-card {
        background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 20px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  

  
  .project-header {
    display: flex;
    margin-bottom: 12px;
    text-decoration: none;
  }

  .project-header-link {
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .project-header-link:hover .project-name {
    color: var(--theme-color);
  }

  .project-header-link:hover .project-link-indicator {
    color: var(--theme-color);
    transform: translate(2px, -2px);
  }

  .project-name {
    font-size: calc(var(--font-title-size) - 2px);
    color: var(--title-color);
    margin: 0;
    line-height: 1.3;
    flex: 1;
    transition: color 0.3s ease;
  }

  .project-link-indicator {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--desc-color);
    margin-left: auto;
    margin-right: 8px;
    transition: all 0.3s ease;
  }

  .project-link-arrow {
    width: 20px;
    height: 20px;
  }
  
  .project-language {
    position: absolute;
    top: 0;
    right: 0;
    width: 100px;
    height: 100px;
    opacity: 0.1;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 10px;
  }
  
  .project-language-icon {
    width: 80px;
    height: 80px;
    color: var(--theme-color);
  }
  
  .project-description {
    font-size: var(--font-text-size);
    color: var(--desc-color);
    margin-bottom: 10px;
    line-height: 1.6;
  }
  
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tag-icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: 50%;
    transition: all 0.3s ease;
    cursor: pointer;
    background-color: var(--card-bg);
  }

  .tag-icon-wrapper:hover {
    background-color: var(--theme-color);
    border-color: var(--theme-color);
    transform: scale(1.1);
  }

  .tags-icon {
    width: 18px;
    height: 18px;
    color: var(--text-color);
    transition: color 0.3s ease;
  }

  .tag-icon-wrapper:hover .tags-icon {
    color: white;
  }

  .project-stats {
    display: flex;
    gap: 16px;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--desc-color);
  }

  .stat-item > svg {
    width: 16px;
    height: 16px;
    color: var(--desc-color);
  }

  .stat-count {
    font-weight: 500;
    color: var(--text-color);
  }

  .preview-link {
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .preview-link:hover {
    color: var(--theme-color);
  }

  .preview-link:hover .stat-icon {
    color: var(--theme-color);
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
  }


  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--gap);
    }
    
    .project-card {
      padding: 16px;
    }
    
    .project-name {
      font-size: calc(var(--font-title-size) - 2px);
    }
    
    .project-stats {
      font-size: var(--font-desc-size);
    }
    
    .project-description {
      font-size: calc(var(--font-text-size) - 2px);
    }
    
    .project-tags span {  
      font-size: var(--font-desc-size);
    }
  }
</style>