---
import { SiteConfig } from '../config.ts';
import Layout from '../layouts/Layout.astro';
import { Icon } from "astro-icon/components";
import { parseRss, type Article } from '../utils/RSSParser';
import { links } from '../data/links';

interface ArticleWithSource extends Article {
  sourceName: string;
  sourceAvatar: string;
  sourceUrl: string;
  publishTimeTimestamp: number;
}

// 配置
const LIMIT = 20;
const TIMEOUT = 5000;
const BATCH_SIZE = 3;

// 获取URL模式参数
let mode: 'time' | 'random' = 'time';
try {
  const url = new URL(Astro.request.url);
  mode = url.searchParams.get('mode') === 'random' ? 'random' : 'time';
} catch { /* 静态生成使用默认值 */ }

// 筛选有RSS的友链
const rssLinks = links.filter(link => link.rss?.trim());

// 获取RSS文章
async function fetchArticles(): Promise<ArticleWithSource[]> {
  const allArticles: ArticleWithSource[] = [];
  
  for (let i = 0; i < rssLinks.length; i += BATCH_SIZE) {
    const batch = rssLinks.slice(i, i + BATCH_SIZE);
    const results = await Promise.all(
      batch.map(async link => {
        try {
          const articles = await Promise.race([
            parseRss(link.rss!),
            new Promise<never>((_, reject) => 
              setTimeout(() => reject(new Error('timeout')), TIMEOUT)
            )
          ]);
          
          return articles
            .filter(a => a.title !== '加载失败')
            .slice(0, 5)
            .map(a => ({
              ...a,
              sourceName: link.name,
              sourceAvatar: link.avatar,
              sourceUrl: link.url,
              publishTimeTimestamp: new Date(a.publishTime).getTime() || 0
            }));
        } catch {
          return [];
        }
      })
    );
    allArticles.push(...results.flat());
  }
  
  // 按模式处理
  if (mode === 'time') {
    return allArticles
      .sort((a, b) => b.publishTimeTimestamp - a.publishTimeTimestamp)
      .slice(0, LIMIT);
  }
  
  // 随机模式：Fisher-Yates洗牌
  for (let i = allArticles.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [allArticles[i], allArticles[j]] = [allArticles[j], allArticles[i]];
  }
  return allArticles.slice(0, LIMIT);
}

const articles = await fetchArticles();
---

<Layout pagetitle={`鱼塘 - ${SiteConfig.title}`}>
  <div class="circle-container">
    <h1 class="page-title">鱼塘</h1>
    <p class="circle-subtitle">看看朋友们在干嘛</p>
    
    <div class="mode-switcher">
      <a href="?mode=time" class={`mode-btn ${mode === 'time' ? 'active' : ''}`} data-mode="time">
        <Icon name="tabler:clock" class="mode-icon" />
        最新动态
      </a>
      <a href="?mode=random" class={`mode-btn ${mode === 'random' ? 'active' : ''}`} data-mode="random">
        <Icon name="tabler:star" class="mode-icon" />
        随机分享
      </a>
    </div>
    
    <div class="circle-post-list" id="articles-container">
      {articles.length === 0 ? (
        <div class="empty-state">暂无文章数据</div>
      ) : (
        articles.map((article, i) => (
          <article class="circle-post-item" style={`animation-delay: ${i * 0.05}s`}>
            <a href={article.link} target="_blank" rel="noopener noreferrer" class="circle-post-link">
              <h2 class="circle-post-title">
                {article.title}
                <Icon name="tabler:arrow-up-right" class="post-link-icon" />
              </h2>
              <p class="circle-post-desc">{article.summary}</p>
            </a>
            <div class="circle-origin">
              <div class="origin-left">
                <img src={article.sourceAvatar} alt={article.sourceName} class="author-avatar" loading="lazy" />
                <span>{article.sourceName}</span>
              </div>
              <span>{article.publishTime}</span>
            </div>
          </article>
        ))
      )}
    </div>
  </div>
</Layout>

<script>
  (function() {
    const url = new URL(window.location.href);
    const mode = url.searchParams.get('mode') || 'time';
    
    // 更新按钮状态
    document.querySelectorAll('.mode-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.mode === mode);
    });
    
    // 随机模式：客户端重新打乱
    if (mode === 'random') {
      const container = document.getElementById('articles-container');
      if (!container) return;
      
      const items = Array.from(container.querySelectorAll('.circle-post-item'));
      items.sort(() => Math.random() - 0.5).forEach((item, i) => {
        item.style.animationDelay = `${i * 0.05}s`;
        container.appendChild(item);
      });
    }
  })();
</script>

<style>
  .circle-container {
    max-width: var(--width);
    margin: 0 auto;
  }
  
  .page-title {
    font-size: var(--font-title-size);
    font-weight: 600;
    color: var(--title-color);
    text-align: center;
    margin-bottom: 10px;
  }
  
  .circle-subtitle {
    font-size: calc(var(--font-title-size) - 4px);
    color: var(--desc-color);
    text-align: center;
    margin-bottom: 20px;
  }
  
  .mode-switcher {
    display: flex;
    gap: 12px;
    margin-bottom: 30px;
  }
  
  .mode-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    color: var(--text-color);
    font-size: var(--font-desc-size);
    text-decoration: none;
    transition: all 0.3s;
  }
  
  .mode-btn:hover, .mode-btn.active {
    color: var(--theme-color);
  }
  
  .mode-btn.active {
    color: var(--theme-color);
  }
  
  .mode-icon { width: 16px; height: 16px; }
  
  .circle-post-list {
    column-count: 2;
    column-gap: 16px;
  }
  
  .circle-post-item {
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    background: var(--card-bg);
    margin-bottom: 16px;
    break-inside: avoid;
    opacity: 0;
    animation: slideIn 0.5s forwards;
    transition: all 0.3s;
  }
  
  .circle-post-item:hover {
    border-color: var(--theme-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-color);
  }
  
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .circle-post-link {
    display: block;
    padding: 15px 15px 10px;
    text-decoration: none;
    color: inherit;
  }
  
  .circle-post-title {
    font-size: calc(var(--font-title-size) - 2px);
    font-weight: 500;
    color: var(--title-color);
    line-height: 1.4;
    margin-bottom: 8px;
  }
  
  .post-link-icon {
    width: 16px;
    height: 16px;
    display: inline-block;
    vertical-align: middle;
    margin-top: -2px;
  }
  
  .circle-post-desc {
    font-size: var(--font-desc-size);
    color: var(--desc-color);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .circle-origin {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    border-top: 1px solid var(--border-color);
    font-size: var(--font-desc-size);
    color: var(--desc-color);
  }
  
  .origin-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .author-avatar {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 50px;
    color: var(--desc-color);
  }
  
  @media (max-width: 768px) {
    .circle-post-list { column-count: 1; }
    .circle-post-link { padding: 12px 12px 8px; }
    .circle-origin { padding: 8px 12px 12px; }
    .author-avatar { width: 18px; height: 18px; }
  }
</style>
