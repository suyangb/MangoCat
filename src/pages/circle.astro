---
import { SiteConfig } from '../config.ts';
import Layout from '../layouts/Layout.astro';
import { links } from '../data/links';

import Fishpond from '../components/Fishpond.astro';
---
<Layout pagetitle={`鱼塘 - ${SiteConfig.title}`}>
  <div class="circle-container">
    <h1 class="text-3xl font-bold">鱼塘（beta）</h1>
    <p class="circle-subtitle">看看朋友们在干嘛</p>
    
    <div class="circle-content">
      <Fishpond />
    </div>
  </div>
</Layout>

<style>
  .circle-container {
    max-width: var(--width);
    margin: 0 auto;
  }
  
  .circle-subtitle {
    font-size: 1.2rem;
    color: var(--text-color);
    margin-bottom: 25px;
  }
  
  .circle-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  
  .circle-year {
    border-radius: var(--radius);
  }
  
  .circle-year-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--title-color);
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .circle-post-count {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-color);
    background-color: var(--info-bg-color);
    padding: 4px 12px;
    border-radius: var(--radius);
  }
  
  .circle-post-list {
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }
  
  .circle-post-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .circle-post-item:hover {
    border-color: var(--theme-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-color);
  }
  
  .circle-post-link {
    text-decoration: none;
    color: var(--title-color);
    display: flex;
    align-items: center;
    gap: 15px;
    width: 100%;
    height: 100%;
    padding: 10px 15px;
  }
  
  .author-avatar {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    object-fit: cover;
    flex-shrink: 0;
  }

  .circle-post-date {
    font-size: 1rem;
    color: var(--info-font-color);
    font-weight: 500;
  }
  
  .circle-post-title {
    font-size: 1rem;
    font-weight: 500;
    flex: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }
  
  .circle-post-author {
    font-size: 1rem;
    color: var(--text-color);
    margin-left: 10px;
    background-color: var(--info-bg-color);
    padding: 2px 8px;
    border-radius: var(--radius);
    flex-shrink: 0;
  }
  
  .empty-state {
    text-align: center;
    padding: 50px 0;
    color: var(--text-color);
  }

</style>
