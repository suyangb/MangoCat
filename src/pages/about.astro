---
import AboutPage from "../content/about.md";
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { SiteConfig ,ProfileConfig } from "../config";
import { Picture } from "astro:assets";

const Page = '关于';

// 计算网站运营时间
const createTime = new Date(SiteConfig.createTime);
const now = new Date();
const diffTime = now.getTime() - createTime.getTime();
const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
const diffYears = Math.floor(diffDays / 365);
const remainingDays = diffDays % 365;

let runtimeText = "";
if (diffYears > 0) {
    runtimeText = `${diffYears}年${remainingDays}天`;
} else {
    runtimeText = `${diffDays}天`;
}

// 技术栈列表
const skills = [
    { icon: "devicon:html5", name: "HTML5" },
    { icon: "devicon:css3", name: "CSS3" },
    { icon: "devicon:javascript", name: "JavaScript" },
    { icon: "devicon:typescript", name: "TypeScript" },
    { icon: "devicon:nodejs", name: "Node.js" },
    { icon: "devicon:astro", name: "Astro" },
    { icon: "devicon:python", name: "Python" },
    { icon: "devicon:csharp", name: "C#" },
    { icon: "devicon:cplusplus", name: "C++" },
    { icon: "devicon:vuejs", name: "Vue" },
    { icon: "devicon:dart", name: "Dart" },
];

// 工具列表
const tools = [
    { icon: "devicon:windows11", name: "Windows" },
    { icon: "devicon:android", name: "Android" },
    { icon: "devicon:vscode", name: "VS Code" },
    { icon: "devicon:visualstudio", name: "Visual Studio" },
    { icon: "devicon:chrome", name: "Chrome" },
    { icon: "devicon:git", name: "Git" },
    { icon: "devicon:github", name: "GitHub" },
    { icon: "devicon:vercel", name: "Vercel" },
    { icon: "devicon:pnpm", name: "pnpm" },

    { icon: "devicon:photoshop", name: "Photoshop" },
];
---

<Layout pagetitle={`${Page} - ${SiteConfig.title}`}>
    <h1 class="text-2xl font-bold text-center" style="color: var(--title-color);">{Page}</h1>
    <p class="text-center mb-[30px]">关于我是谁</p>
    <div class="about-content animate__animated animate__fadeInUp">
        <div class="about-introduction">
            <p>你好，我是啊芒果，欢迎来到我的博客。</p>
            <p>我是个业余前端爱好者，喜欢折腾前端设计和折腾各种小项目。</p>
            <p>爱好打游戏、💤睡觉、🎵听音乐、<del>运动</del>、设计、看番、拍摄、遛猫......</p>
            <p>认为世界上最好吃的食物是：🍨冰激凌、🥭芒果</p>
            <p>座右铭：<span>“{ProfileConfig.desc}”</span></p>
            <b>MBTI鉴定为：<span style="color: var(--theme-color); font-weight: 600;">
                <a href="https://www.16personalities.com/ch/infj-人格" target="_blank">
                    INFJ-T
                </a>
            </span>
        </b>

        </div>
        <div class="about-section">
            <h2 class="section-title">技术栈</h2>
            <div class="about-skill">
                {
                    skills.map((skill) => (
                        <div class="skill-item">
                            <Icon name={skill.icon} class="skill-icon" />
                            <span>{skill.name}</span>
                        </div>
                    ))
                }
            </div>
        </div>

        <div class="about-section">
            <h2 class="section-title">开发工具</h2>
            <div class="about-tool">
                {
                    tools.map((tool) => (
                        <div class="tool-item">
                            <Icon name={tool.icon} class="tool-icon" />
                            <span>{tool.name}</span>
                        </div>
                    ))
                }
            </div>
        </div>
         <div class="about-section">
            <h2 class="section-title">关于网站</h2>
            <div class="about-introduction">
            <p>框架与主题： <a href="https://astro.build/" target="_blank">Astro</a> & <a href="https://github.com/almango/MangoCat" target="_blank">MangoCat</a></p>
            <p>构建与部署： <a href="https://github.com/" target="_blank">GitHub</a> + <a href="https://vercel.com/" target="_blank">Vercel</a></p>
            <p>本站已默默运行了 <span class="runtime">{runtimeText}</span></p>
            <p>这不仅仅是我的博客，更是我的秘密基地，对生活、技术的思考与实践，我都认真记录于此。</p>
            <p>如果你对本网站的内容有任何问题或建议，欢迎随时联系我，我将在第一时间处理。</p>
            <p>邮箱：<span>sliveralmango@outlook.com</span></p> 
        </div>
        </div>
    </div>
</Layout>

<style>
    .about-content {
        margin: 0 auto;
    }

    .about-introduction {
        margin-bottom: 40px;
        color: var(--text-color);
        line-height: 1.8;
    }

    .about-introduction p {
        margin: 10px 0;
    }
    .about-section {
        margin-bottom: 40px;
    }

    .section-title {
        font-size: var(--font-title-size);
        color: var(--title-color);
        margin-bottom: 12px;
    }

    .about-skill,
    .about-tool {
        display: flex;
        flex-wrap: wrap;
        gap: var(--gap);
    }

    .skill-item,
    .tool-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        background-color: var(--card-bg);
        border-radius: var(--radius);
        border: 1px solid var(--border-color);
        cursor: pointer;
    }

    .skill-icon,
    .tool-icon {
        width: 18px;
        height: 18px;
    }

    .skill-item span,
    .tool-item span {
        color: var(--text-color);
        font-size: var(--font-desc-size);
    }
    .runtime {
        color: var(--title-color) !important;
        font-weight: 500;
    }
    @media (max-width: 768px) {
        .about-skill,
        .about-tool {
            gap: 10px;
        }

        .skill-item,
        .tool-item {
            padding: 6px 10px;
        }

        .skill-icon,
        .tool-icon {
            width: 16px;
            height: 16px;
        }
    }
</style>
