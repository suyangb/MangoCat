---
import { Icon } from "astro-icon/components";
import { ThemeScript } from "astro-theme-toggle/components";
import { Toggle } from "astro-theme-toggle/components";
import { SiteConfig } from "../config.ts";
const { NavConfig } = SiteConfig;
import Search from "./Search.astro";
---

<header class="header">
    <div class="container">
        <a href="/" class="logo-button">
            <Icon name="tabler:home" />
        </a>
        
        <nav class="nav-container">
            <ul class="nav-links">
                {NavConfig.map((navItem) => (
                    <li>
                        <a href={navItem.path}>{navItem.name}</a>
                    </li>
                ))}
            </ul>
        </nav>
        
        <!-- 右侧按钮组：主题切换和导航折叠 -->
        <div class="header-buttons">
            <ThemeScript />
            <Toggle class="theme-toggle" style={{ width: "32px", height: "32px" }} />
            
            <!-- 移动端导航折叠按钮 -->
            <button class="nav-toggle" aria-label="打开导航">
                <Icon name="tabler:menu-4" />
            </button>
        </div>
    </div>
    
    <script>
        // 移动端导航切换逻辑
        const navToggle = document.querySelector('.nav-toggle');
        const navContainer = document.querySelector('.nav-container');
        
        navToggle?.addEventListener('click', () => {
            navContainer?.classList.toggle('nav-open');
        });
        
        // 导航栏滚动显示/隐藏逻辑
        let lastScrollTop = 0;
        const header = document.querySelector('.header');
        
        if (header) {
            window.addEventListener('scroll', () => {
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                
                if (scrollTop > lastScrollTop && scrollTop > 200) {
                    // 向下滚动且超过100px，隐藏导航栏
                    header.classList.add('header-hidden');
                } else {
                    // 向上滚动，显示导航栏
                    header.classList.remove('header-hidden');
                }
                
                lastScrollTop = scrollTop;
            });
        }
    </script>

    <style>
        .header {
            padding: 15px 15px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            width: 100%;
            box-sizing: border-box;
            transition: transform 0.3s ease;
        }

        .header.header-hidden {
            transform: translateY(-100%);
        }

        .container {
            border-radius: 50px;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 8px 8px;
            width: 100%;
            max-width: var(--width);
            box-sizing: border-box;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .logo-button {
            border: 1px solid var(--border-color);
            background-color: transparent;
            border-radius: var(--radius);
            padding: 6px;
            cursor: pointer;
            font-size: 14px;
            color: var(--text-color);
            transition: all 0.3s ease;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
        }

        .logo-button:hover {
            background-color: var(--hover-color);
            border-color: var(--theme-color);
        }

        .logo-button svg {
            width: 16px;
            height: 16px;
        }

        /* 导航容器 */
        .nav-container {
            margin-left: auto;
            margin-right: 20px;
            flex: 1;
            display: flex;
            justify-content: flex-end;
        }

        .nav-links {
            display: flex;
            gap: 25px;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .nav-links li a {
            text-decoration: none;
            color: var(--text-color);
            font-size: 15px;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
            padding: 8px 0;
        }

        .nav-links li a:hover {
            color: var(--theme-color);
        }

        .nav-links li a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--theme-color);
            transition: width 0.3s ease;
        }

        .nav-links li a:hover::after {
            width: 100%;
        }

        /* 移动端导航切换按钮 */
        .header-buttons {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-toggle {
            display: none;
            background: none;
            border: none;
            border: 1px solid var(--border-color);
            background-color: transparent;
            border-radius: var(--radius);
            padding: 6px;
            color: var(--text-color);
            font-size: 18px;
            cursor: pointer;
            line-height: 1;
            align-items: center;
            justify-content: center;
        }

        .nav-toggle:hover {
            background-color: var(--hover-color);
            border-color: var(--theme-color);
        }

        .theme-toggle {
            border: 1px solid var(--border-color);
            background-color: transparent;
            border-radius: var(--radius);
            padding: 6px;
            cursor: pointer;
            font-size: 14px;
            color: var(--text-color);
            transition: all 0.3s ease;
        }

        .theme-toggle:hover {
            background-color: var(--hover-color);
            border-color: var(--theme-color);
        }

        /* 响应式设计 */
        @media (max-width: 768px) {
            .nav-toggle {
                display: flex;
            }

            .nav-container {
                text-align: center;
                position: absolute;
                top: calc(100% + 8px);
                right: 0;
                background-color: var(--card-bg);
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease, opacity 0.3s ease;
                margin-right: 0;
                flex-direction: column;
                justify-content: flex-start;
                box-shadow: 0 4px 12px var(--shadow-color);
                border-radius: var(--radius);
                border: 1px solid var(--border-color);
                opacity: 0;
                width: 120px;
                box-sizing: border-box;
            }

            .nav-container.nav-open {
                max-height: 300px;
                opacity: 1;
            }

            .nav-links {
                flex-direction: column;
                padding: 20px;
                gap: 8px;
                width: 100%;
                box-sizing: border-box;
            }

            .nav-links li {
                width: 100%;
                border-radius: var(--radius);
                transition: background-color 0.3s ease;
            }

            .nav-links li:hover {
                background-color: var(--hover-color);
            }

            .nav-links li a {
                font-size: 16px;
                width: 100%;
                display: block;
                padding: 10px 15px;
                border-radius: var(--radius);
            }

            .nav-links li a::after {
                display: none;
            }

            .container {
                padding: 8px 8px;
            }

            .header-buttons {
                gap: 8px;
            }
        }
    </style>
</header>