---
import { links } from '../data/links';

// 原生方式解析RSS的函数
async function fetchRSSFeed(url: string) {
  try {
    const response = await Promise.race([
      fetch(url, { 
        headers: { 'User-Agent': 'Mozilla/5.0' },
        signal: AbortSignal.timeout(3000)
      }),
      new Promise((_, reject) => setTimeout(() => reject(new Error('Request timeout')), 3000))
    ]) as Response;
    
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    
    const xmlText = await response.text();
    
    const items: any[] = [];
    let match;
    
    // 尝试匹配RSS格式的item标签
    const rssItemRegex = /<item>([\s\S]*?)<\/item>/gi;
    while ((match = rssItemRegex.exec(xmlText)) !== null) {
      const item = match[1];
      
      const titleMatch = item.match(/<title>(.*?)<\/title>/i);
      const title = titleMatch ? titleMatch[1].trim() : '';
      
      const linkMatch = item.match(/<link>(.*?)<\/link>/i);
      const link = linkMatch ? linkMatch[1].trim() : '';
      
      const pubDateMatch = item.match(/<pubDate>(.*?)<\/pubDate>/i);
      const pubDate = pubDateMatch ? new Date(pubDateMatch[1].trim()) : new Date(0);
      
      if (title && link && !isNaN(pubDate.getTime())) {
        items.push({ title, link, pubDate });
      }
    }
    
    // 尝试匹配Atom格式的entry标签
    const atomEntryRegex = /<entry>([\s\S]*?)<\/entry>/gi;
    while ((match = atomEntryRegex.exec(xmlText)) !== null) {
      const entry = match[1];
      
      const titleMatch = entry.match(/<title(?:[^>]*?)>(.*?)<\/title>/i);
      const title = titleMatch ? titleMatch[1].trim() : '';
      
      const linkMatch = entry.match(/<link[^>]*?href=["'](.*?)["'][^>]*?>/i);
      const link = linkMatch ? linkMatch[1].trim() : '';
      
      const updatedMatch = entry.match(/<updated>(.*?)<\/updated>/i);
      const pubDate = updatedMatch ? new Date(updatedMatch[1].trim()) : new Date(0);
      
      if (title && link && !isNaN(pubDate.getTime())) {
        items.push({ title, link, pubDate });
      }
    }
    
    return { items };
  } catch (error) {
    console.error(`RSS fetch failed: ${url}`);
    return null;
  }
}

// 限制并发请求函数
async function fetchWithConcurrencyLimit(urls: string[], limit: number, fetchFn: (url: string) => Promise<any>) {
  const results: any[] = [];
  const executing: Promise<any>[] = [];
  
  for (const url of urls) {
    const p = Promise.resolve().then(() => fetchFn(url));
    results.push(p);
    
    if (urls.length >= limit) {
      const e = p.then(() => executing.splice(executing.indexOf(e), 1));
      executing.push(e);
      
      if (executing.length >= limit) {
        await Promise.race(executing);
      }
    }
  }
  
  return Promise.all(results);
}

// 并行获取所有RSS文章
async function getAllRSSArticles() {
  const rssLinks = links.filter(link => link.rss);
  
  const rssPromises = await fetchWithConcurrencyLimit(
    rssLinks.map(link => link.rss!),
    5,
    async (url) => {
      const link = rssLinks.find(l => l.rss === url)!;
      try {
        const feed = await fetchRSSFeed(url);
        if (feed && feed.items) {
          return feed.items.map((item: any) => ({
            title: item.title,
            link: item.link,
            pubDate: item.pubDate,
            author: link.name,
            avatar: link.avatar,
            blogUrl: link.url
          }));
        }
        return [];
      } catch (error) {
        return [];
      }
    }
  );
  
  const articles: any[] = [];
  rssPromises.forEach(result => {
    if (Array.isArray(result) && result.length > 0) {
      articles.push(...result);
    }
  });
  
  return articles.sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
}

// 构建时获取初始数据（可选，用于SEO和首屏加载）
const initialArticles = await getAllRSSArticles();
---

<div class="fishpond-container">
  <div class="archive-post-list" id="fishpond-articles">
    {initialArticles.slice(0, 20).length > 0 ? (
      initialArticles.slice(0, 20).map((article, index) => {
        const postDate = article.pubDate;
        const monthDay = postDate.toISOString().substring(5, 10);
        return (
          <div class="archive-post-item animate-slide-in" key={index} style={{ animationDelay: `${index * 0.05}s` }}>
            <a href={article.link} target="_blank" rel="noopener noreferrer" class="archive-post-link">
              <img src={article.avatar} alt={article.author} class="author-avatar" />
              <span class="archive-post-date">
                {monthDay}
              </span>
              <span class="archive-post-title">{article.title}</span>
              <span class="archive-post-author">{article.author}</span>
            </a>
          </div>
        );
      })
    ) : (
      <div class="empty-state">
        <p>暂无文章</p>
      </div>
    )}
  </div>
  

</div>

<script>
  // 客户端脚本，用于页面加载时自动获取最新文章
  document.addEventListener('DOMContentLoaded', async () => {
    const articlesContainer = document.getElementById('fishpond-articles');
    
    if (!articlesContainer) return;
    
    // 重新获取文章的函数
    async function fetchLatestArticles() {
      try {
        // 重新执行获取RSS的逻辑
        const links = JSON.parse('{{ JSON.stringify(links) }}');
        
        // 原生方式解析RSS的函数
        async function fetchRSSFeed(url) {
          try {
            const response = await Promise.race([
              fetch(url, { 
                headers: { 'User-Agent': 'Mozilla/5.0' },
                signal: AbortSignal.timeout(3000)
              }),
              new Promise((_, reject) => setTimeout(() => reject(new Error('Request timeout')), 3000))
            ]);
            
            if (!response.ok) {
              throw new Error(`HTTP error! status: ${response.status}`);
            }
            
            const xmlText = await response.text();
            
            const items = [];
            let match;
            
            // 尝试匹配RSS格式的item标签
            const rssItemRegex = /<item>([\s\S]*?)<\/item>/gi;
            while ((match = rssItemRegex.exec(xmlText)) !== null) {
              const item = match[1];
              
              const titleMatch = item.match(/<title>(.*?)<\/title>/i);
              const title = titleMatch ? titleMatch[1].trim() : '';
              
              const linkMatch = item.match(/<link>(.*?)<\/link>/i);
              const link = linkMatch ? linkMatch[1].trim() : '';
              
              const pubDateMatch = item.match(/<pubDate>(.*?)<\/pubDate>/i);
              const pubDate = pubDateMatch ? new Date(pubDateMatch[1].trim()) : new Date(0);
              
              if (title && link && !isNaN(pubDate.getTime())) {
                items.push({ title, link, pubDate });
              }
            }
            
            // 尝试匹配Atom格式的entry标签
            const atomEntryRegex = /<entry>([\s\S]*?)<\/entry>/gi;
            while ((match = atomEntryRegex.exec(xmlText)) !== null) {
              const entry = match[1];
              
              const titleMatch = entry.match(/<title(?:[^>]*?)>(.*?)<\/title>/i);
              const title = titleMatch ? titleMatch[1].trim() : '';
              
              const linkMatch = entry.match(/<link[^>]*?href=["'](.*?)["'][^>]*?>/i);
              const link = linkMatch ? linkMatch[1].trim() : '';
              
              const updatedMatch = entry.match(/<updated>(.*?)<\/updated>/i);
              const pubDate = updatedMatch ? new Date(updatedMatch[1].trim()) : new Date(0);
              
              if (title && link && !isNaN(pubDate.getTime())) {
                items.push({ title, link, pubDate });
              }
            }
            
            return { items };
          } catch (error) {
            console.error(`RSS fetch failed: ${url}`);
            return null;
          }
        }
        
        // 限制并发请求函数
        async function fetchWithConcurrencyLimit(urls, limit, fetchFn) {
          const results = [];
          const executing = [];
          
          for (const url of urls) {
            const p = Promise.resolve().then(() => fetchFn(url));
            results.push(p);
            
            if (urls.length >= limit) {
              const e = p.then(() => executing.splice(executing.indexOf(e), 1));
              executing.push(e);
              
              if (executing.length >= limit) {
                await Promise.race(executing);
              }
            }
          }
          
          return Promise.all(results);
        }
        
        // 并行获取所有RSS文章
        async function getAllRSSArticles() {
          const rssLinks = links.filter(link => link.rss);
          
          const rssPromises = await fetchWithConcurrencyLimit(
            rssLinks.map(link => link.rss),
            5,
            async (url) => {
              const link = rssLinks.find(l => l.rss === url);
              try {
                const feed = await fetchRSSFeed(url);
                if (feed && feed.items) {
                  return feed.items.map((item) => ({
                    title: item.title,
                    link: item.link,
                    pubDate: item.pubDate,
                    author: link.name,
                    avatar: link.avatar,
                    blogUrl: link.url
                  }));
                }
                return [];
              } catch (error) {
                return [];
              }
            }
          );
          
          const articles = [];
          rssPromises.forEach(result => {
            if (Array.isArray(result) && result.length > 0) {
              articles.push(...result);
            }
          });
          
          return articles.sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
        }
        
        // 获取最新文章
        const allArticles = await getAllRSSArticles();
        const articles = allArticles.slice(0, 20);
        
        // 更新DOM
        articlesContainer.innerHTML = '';
        
        if (articles.length > 0) {
          articles.forEach((article, index) => {
            const postDate = new Date(article.pubDate);
            const monthDay = postDate.toISOString().substring(5, 10);
            
            const articleEl = document.createElement('div');
            articleEl.className = 'archive-post-item animate-slide-in';
            articleEl.style.animationDelay = `${index * 0.05}s`;
            articleEl.innerHTML = `
              <a href="${article.link}" target="_blank" rel="noopener noreferrer" class="archive-post-link">
                <img src="${article.avatar}" alt="${article.author}" class="author-avatar" />
                <span class="archive-post-date">${monthDay}</span>
                <span class="archive-post-title">${article.title}</span>
                <span class="archive-post-author">${article.author}</span>
              </a>
            `;
            
            articlesContainer.appendChild(articleEl);
          });
        } else {
          articlesContainer.innerHTML = `
            <div class="empty-state">
              <p>暂无文章</p>
            </div>
          `;
        }
        
      } catch (error) {
        console.error('Failed to fetch latest articles:', error);
      }
    }
    
    // 页面加载时自动获取最新文章
    fetchLatestArticles();
  });
</script>

<style>
  .fishpond-container {
    width: 100%;
  }
  
  .archive-post-list {
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  
  .archive-post-item {
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .archive-post-item:hover {
    border-color: var(--theme-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-color);
  }
  
  .archive-post-link {
    text-decoration: none;
    color: var(--title-color);
    display: flex;
    align-items: center;
    gap: 15px;
    width: 100%;
    height: 100%;
    padding: 10px 15px;
  }
  
  .author-avatar {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    object-fit: cover;
    flex-shrink: 0;
  }
  
  .archive-post-date {
    font-size: 15px;
    color: var(--info-font-color);
    font-weight: 500;
  }
  
  .archive-post-title {
    font-size: 15px;
    font-weight: 500;
    flex: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }
  
  .archive-post-author {
    font-size: 13px;
    color: var(--text-color);
    margin-left: 10px;
    background-color: var(--info-bg-color);
    padding: 2px 8px;
    border-radius: var(--radius);
    flex-shrink: 0;
  }
  
  .empty-state {
    text-align: center;
    padding: 50px 0;
    color: var(--text-color);
  }
  
  /* 动画效果 */
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-slide-in {
    animation: slideIn 0.5s ease forwards;
  }
  
  /* 响应式设计 */
  @media (max-width: 768px) {
    .archive-post-date {
      min-width: 20px;
    }
    
    .archive-post-item {
      padding: 0;
    }
    
    .archive-post-link, .archive-post-link span {
      gap: 10px;
      font-size: 14px;
    }
    
    .author-avatar {
      width: 24px;
      height: 24px;
    }
    
    /* 在移动端隐藏作者名称 */
    .archive-post-author {
      display: none;
    }
  }
</style>